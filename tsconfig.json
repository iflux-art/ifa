{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["dom", "dom.iterable", "es2024"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@repo/ui": ["./packages/ui/src"],
      "@repo/utils": ["./packages/utils/src"],
      "@iflux-art/ui": ["./packages/ui/src"],
      "@iflux-art/ui/theme-provider": [
        "./packages/ui/src/components/theme/theme-provider.tsx"
      ],
      "@iflux-art/ui/components/theme/theme-toggle": [
        "./packages/ui/src/components/theme/theme-toggle.tsx"
      ],
      "@iflux-art/ui/components/ui/button/github-button": [
        "./packages/ui/src/components/ui/button/github-button.tsx"
      ],
      "@iflux-art/ui/components/ui/button/travel-button": [
        "./packages/ui/src/components/ui/button/travel-button.tsx"
      ],
      "@iflux-art/ui/components/ui/button/user-button": [
        "./packages/ui/src/components/ui/button/user-button.tsx"
      ]
    }
  },
  "files": ["tsconfig.json"],
  "exclude": ["node_modules"]
}
