{
  "name": "@iflux-art/ui",
  "version": "0.1.19",
  "description": "A modern React UI component library based on shadcn/ui design system",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint .",
    "format": "biome format .",
    "check": "biome check .",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "shadcn",
    "radix-ui",
    "tailwindcss"
  ],
  "author": "Bowie <hello@iflux.art>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iflux-art/ifa.git"
  },
  "bugs": {
    "url": "https://github.com/iflux-art/ifa/issues"
  },
  "homepage": "https://github.com/iflux-art/ifa#readme",
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.525.0",
    "mermaid": "^11.4.0",
    "next": "^15.5.3",
    "next-themes": "^0.4.6",
    "prismjs": "^1.30.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@chromatic-com/storybook": "^4.1.1",
    "@storybook/addon-essentials": "^9.0.0-alpha.12",
    "@storybook/addon-interactions": "^9.0.0-alpha.10",
    "@storybook/addon-links": "^9.1.6",
    "@storybook/addon-onboarding": "^9.1.6",
    "@storybook/blocks": "^9.0.0-alpha.17",
    "@storybook/nextjs": "^9.1.7",
    "@storybook/react": "^9.1.6",
    "@storybook/react-vite": "^9.0.0-alpha.12",
    "@storybook/test": "^9.0.0-alpha.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.10",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "chromatic": "^13.2.0",
    "jsdom": "^23.0.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "storybook": "^9.1.6",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.6",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "engines": {
    "node": "22.x",
    "pnpm": "9.15.9"
  },
  "packageManager": "pnpm@9.15.9",
  "exports": {
