    "./back-button": {
      "types": "./dist/components/ui/back-button.d.ts",
      "import": "./dist/components/ui/back-button.js"
    },
    "./badge": {
      "types": "./dist/components/ui/badge.d.ts",
      "import": "./dist/components/ui/badge.js"
    },
    "./not-found": {
      "types": "./dist/components/ui/not-found.d.ts",
